# Google Workspace Sign-In — same OAuth Client ID as the backend's GOOGLE_CLIENT_ID.
# Leave unset to hide the Google sign-in button entirely (email/password login still works).
VITE_GOOGLE_CLIENT_ID=xdxdxdxdxdxdxdxdxdxdxdx

# Leave both of these commented out for LOCAL DEV only. When unset, the frontend calls relative
# paths (/api, /socket.io) which the Vite dev server proxies to the backend on localhost:5000 —
# this works automatically whether you open the app via localhost OR your machine's LAN IP
# (e.g. http://192.168.100.171:5173), with zero reconfiguration.
#
# For a PRODUCTION deployment (e.g. frontend on Vercel, backend on Render), there is no dev
# proxy, so these MUST be set to your backend's real deployed URL. Set them as Environment
# Variables in your Vercel project settings (not in a committed .env file):
# VITE_API_URL=https://your-backend.onrender.com/api
# VITE_SOCKET_URL=https://your-backend.onrender.com

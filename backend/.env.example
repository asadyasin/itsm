# Organization identity (used in QR codes and printable asset labels)
ORG_NAME=Acme Corporation
ORG_DEFAULT_LOCATION=Head Office

# Server
NODE_ENV=development
PORT=5000
# Comma-separated list of allowed frontend origins (no trailing slash). In production this
# MUST be your exact deployed frontend URL(s), e.g.:
# CLIENT_URL=https://itsm.vercel.app,https://itsm-git-staging-yourname.vercel.app
CLIENT_URL=http://localhost:5173

# Database
# For production (Render, etc.) use MongoDB Atlas - create a free cluster, then in Atlas's
# Network Access settings, allow access from anywhere (0.0.0.0/0) since Render's outbound IP
# isn't fixed on the free tier.
MONGO_URI=mongodb://127.0.0.1:27017/itsm_inventory

# JWT
JWT_ACCESS_SECRET=change_this_access_secret
JWT_REFRESH_SECRET=change_this_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Google Workspace Sign-In
# Create an OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# (Application type: Web application). Add your frontend URL(s) under "Authorized JavaScript
# origins" (e.g. http://localhost:5173 and your production domain) - no redirect URI needed,
# this uses Google Identity Services' token flow, not a server-side redirect.
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
# Optional: restrict sign-in to your company's Workspace domain only (blocks personal Gmail
# accounts). Leave blank to allow any Google account.
GOOGLE_WORKSPACE_DOMAIN=yourcompany.com

# Email (Nodemailer / SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASS=your_app_password
EMAIL_FROM="IT Department <it-support@example.com>"

# Uploads
MAX_UPLOAD_MB=10

# Rate limiting
RATE_LIMIT_WINDOW_MIN=15
RATE_LIMIT_MAX=300
